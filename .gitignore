# Agor Claw Workspace - Git Ignore

# === Sensitive / Private Files ===
.env
.env.local
*.pem
*.key
*.cert
id_rsa*
config.json
secrets.*
.claude/settings.json

# === Agor State (runtime tracking) ===
memory/agor-state/*.json

# === Runtime Memory (daily logs, task outputs) ===
memory/*.md
memory/learnings/*.md

# === Ad-hoc scripts and prompts ===
prompt*.md
archive_*.py

# === Python ===
.venv/
__pycache__/
*.pyc
uv.lock
.python-version

# === Agent Runtime ===
.openclaw/
node_modules/
dist/
build/
.turbo/
.next/

# === OS / Editor ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# === Temporary / Cache ===
*.log
*.tmp
.cache/
tmp/
memory/trello-plan-*.json
memory/trello-actions-*.json
memory/filtered-new-sessions-*.json
memory/agor-state/trello-processor.json.OLD
memory/verification-reports/verification-pre-flight-*.json
