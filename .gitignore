# agor-assistant workspace — .gitignore
#
# Reminder: git IS the backup mechanism (see BACKUP.md). Your identity,
# memory, and learnings are MEANT to be committed and pushed to your
# branch. If your branch lives on a public remote, move to a private
# repo rather than ignoring files.

# === Sensitive / Private Files ===
.env
.env.local
*.pem
*.key
*.cert
id_rsa*
config.json
secrets.*
.claude/settings.json

# === Agor State (runtime tracking) ===
memory/agor-state/*.json

# === Runtime Memory (daily logs, task outputs) ===
memory/*.md
memory/learnings/*.md

# === Ad-hoc scripts and prompts ===
prompt*.md
archive_*.py

# === Python ===
.venv/
__pycache__/
*.pyc
uv.lock
.python-version

# === Agent Runtime ===
.openclaw/
node_modules/
dist/
build/
.turbo/
.next/

# === OS / Editor ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# === Temp / Cache ===
*.log
*.tmp
.cache/
tmp/
